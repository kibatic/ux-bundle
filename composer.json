{
    "name": "kibatic/ux-bundle",
    "type": "symfony-bundle",
    "description": "",
    "keywords": [
        "symfony-ux"
    ],
    "homepage": "https://kibatic.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Jérémy Crombez",
            "email": "jeremy.crombez@kibatic.com"
        }
